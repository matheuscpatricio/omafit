{% comment %}
  Descontinuado: MindAR, #omafit-ar-root e omafit-ar-widget.js passaram para o bloco **Omafit embed**
  (quando o produto tem metafield omafit.ar_glb_url e o filtro de tag, se configurado, coincide).
  Remove este bloco dos templates de produto para evitar confusão no editor.
{% endcomment %}
{% if request.design_mode %}
  <div
    style="padding:12px;margin:8px 0;border:1px dashed #b8860b;border-radius:6px;font-size:13px;line-height:1.45;background:#fffbeb;color:#422006;"
    role="status"
  >
    <strong>Omafit AR óculos (legado):</strong>
    o provador MindAR e o script <code>omafit-ar-widget.js</code> estão no bloco
    <strong>Omafit embed</strong>. Remove este bloco e configura AR nas definições do embed.
  </div>
{% endif %}

{% schema %}
{
  "name": "Omafit AR óculos (legado — remover)",
  "target": "body",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    {
      "type": "paragraph",
      "content": "Este bloco já não injeta HTML na loja. Usa apenas o bloco **Omafit embed** no mesmo sítio (body do produto)."
    }
  ]
}
{% endschema %}
