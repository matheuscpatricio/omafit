<div
  id="omafit-widget-root"
  data-ar-mindar-wear-yxz="0, 0, 0"
  data-ar-mindar-wear-position=""
  data-shop-domain="{% if shop.myshopify_domain != blank %}{{ shop.myshopify_domain }}{% else %}{% if shop.domain contains '.myshopify.com' %}{{ shop.domain }}{% else %}{{ shop.domain }}.myshopify.com{% endif %}{% endif %}"
  data-shop-name="{{ shop.name | escape }}"
  {% comment %}
    Handle principal: o mais específico entre as coleções do produto (mais segmentos -/_ , desempate por comprimento).
    Não usar só collection.handle da URL — costuma ser a coleção genérica (ex: cuecas) mesmo existindo cuecas-slips.
  {% endcomment %}
  {% if product and product.collections.size > 0 %}
    {% assign omafit_preferred_handle = '' %}
    {% assign omafit_best_seg = 0 %}
    {% assign omafit_best_len = 0 %}
    {% for c in product.collections %}
      {% assign h = c.handle %}
      {% assign hn = h | replace: '_', '-' %}
      {% assign seg_count = hn | split: '-' | size %}
      {% assign h_len = h | size %}
      {% if seg_count > omafit_best_seg %}
        {% assign omafit_best_seg = seg_count %}
        {% assign omafit_best_len = h_len %}
        {% assign omafit_preferred_handle = h %}
      {% elsif seg_count == omafit_best_seg and h_len > omafit_best_len %}
        {% assign omafit_best_len = h_len %}
        {% assign omafit_preferred_handle = h %}
      {% endif %}
    {% endfor %}
    data-collection-handle="{{ omafit_preferred_handle }}"
    {% assign omafit_coll_handles = product.collections | map: 'handle' | join: ',' %}
    {% if collection %}
      {% assign omafit_url_coll = collection.handle %}
      {% assign omafit_url_in_product_colls = false %}
      {% for c in product.collections %}
        {% if c.handle == omafit_url_coll %}
          {% assign omafit_url_in_product_colls = true %}
          {% break %}
        {% endif %}
      {% endfor %}
      {% unless omafit_url_in_product_colls %}
        {% assign omafit_coll_handles = omafit_coll_handles | append: ',' | append: omafit_url_coll %}
      {% endunless %}
    {% endif %}
    data-collection-handles="{{ omafit_coll_handles }}"
  {% elsif collection %}
    data-collection-handle="{{ collection.handle }}"
    data-collection-handles="{{ collection.handle }}"
  {% endif %}
  {% if product %}
    data-product-id="{{ product.id }}"
    data-product-handle="{{ product.handle }}"
    data-product-title="{{ product.title | escape }}"
    data-product-description="{{ product.description | strip_html | strip_newlines | escape }}"
  {% endif %}
  {% if block.settings.default_gender != blank %}
    data-default-gender="{{ block.settings.default_gender }}"
  {% endif %}
></div>

{% comment %}
  URL do GLB AR (metafield omafit.ar_glb_url) para o iframe Netlify (&arGlbUrl=…) e para MindAR no tema (omafit-ar-widget.js).
{% endcomment %}
{% if product %}
  {% assign omafit_mf_glb = product.metafields.omafit.ar_glb_url %}
  {% assign omafit_ar_glb_url = '' %}
  {% if omafit_mf_glb != blank and omafit_mf_glb.value != blank %}
    {% assign omafit_ar_glb_url = omafit_mf_glb.value | strip %}
  {% endif %}
  {% comment %}
    Calibração do produto (metafield JSON omafit.ar_calibration). Campos:
      rx, ry, rz (graus) ; bridgeY (0..1) ; wearX, wearY, wearZ (m) ; scale.
    Lido do Liquid como JSON (tipo = json no Shopify → hash acessível por chave).
  {% endcomment %}
  {% assign omafit_mf_cal = product.metafields.omafit.ar_calibration %}
  {% assign omafit_cal_json = '' %}
  {% if omafit_mf_cal != blank and omafit_mf_cal.value != blank %}
    {% assign omafit_cal_json = omafit_mf_cal | json %}
  {% endif %}
  <script>
    (function () {
      try {
        var u = {{ omafit_ar_glb_url | json }};
        if (typeof u === 'string' && u.trim()) window.__OMAFIT_AR_GLB_URL__ = u.trim();
      } catch (e) {}
      try {
        var rawCal = {{ omafit_cal_json | default: 'null' }};
        var cal = null;
        if (rawCal && typeof rawCal === 'object' && rawCal.value) {
          try { cal = typeof rawCal.value === 'string' ? JSON.parse(rawCal.value) : rawCal.value; } catch (e) { cal = null; }
        } else if (rawCal && typeof rawCal === 'object') {
          cal = rawCal;
        }
        if (cal && typeof cal === 'object') window.__OMAFIT_AR_CALIBRATION__ = cal;
      } catch (e) {}
      var _variants = [];
      {% for v in product.variants %}
        {% assign v_glb = v.metafields.omafit.ar_glb_url %}
        {% assign v_glb_url = '' %}
        {% if v_glb != blank and v_glb.value != blank %}
          {% assign v_glb_url = v_glb.value | strip %}
        {% endif %}
        {% assign v_cal = v.metafields.omafit.ar_calibration %}
        {% assign v_cal_json = 'null' %}
        {% if v_cal != blank and v_cal.value != blank %}
          {% assign v_cal_json = v_cal | json %}
        {% endif %}
        {% assign v_img = '' %}
        {% if v.featured_image %}
          {% assign v_img = v.featured_image | image_url: width: 200 %}
        {% elsif v.image %}
          {% assign v_img = v.image | image_url: width: 200 %}
        {% endif %}
        (function () {
          var rawVc = {{ v_cal_json }};
          var vc = null;
          if (rawVc && typeof rawVc === 'object' && rawVc.value) {
            try { vc = typeof rawVc.value === 'string' ? JSON.parse(rawVc.value) : rawVc.value; } catch (e) { vc = null; }
          } else if (rawVc && typeof rawVc === 'object') {
            vc = rawVc;
          }
          _variants.push({
            id: {{ v.id | json }},
            title: {{ v.title | json }},
            price: {{ v.price | json }},
            imageUrl: {{ v_img | json }},
            glbUrl: {{ v_glb_url | json }},
            calibration: vc
          });
        })();
      {% endfor %}
      window.__OMAFIT_AR_VARIANTS__ = _variants;
    })();
  </script>

  {% if omafit_ar_glb_url != blank %}
    {% assign glb_url = omafit_ar_glb_url %}
    {% assign product_image_url = '' %}
    {% if product.featured_image %}
      {% assign product_image_url = product.featured_image | image_url: width: 900 %}
    {% elsif product.images.first %}
      {% assign product_image_url = product.images.first | image_url: width: 900 %}
    {% endif %}
    {% assign logo_url = '' %}
    {% if shop.brand.logo != blank %}
      {% assign logo_url = shop.brand.logo | image_url: width: 240 %}
    {% elsif shop.brand.square_logo != blank %}
      {% assign logo_url = shop.brand.square_logo | image_url: width: 240 %}
    {% elsif settings.logo != blank %}
      {% assign logo_url = settings.logo | image_url: width: 240 %}
    {% endif %}
    {% liquid
      assign ar_font_stack = ''
      if settings.type_body_font != blank
        assign ar_font_stack = settings.type_body_font.family | append: ', ' | append: settings.type_body_font.fallback_families
      elsif settings.type_heading_font != blank
        assign ar_font_stack = settings.type_heading_font.family | append: ', ' | append: settings.type_heading_font.fallback_families
      endif
    %}
    {% assign locale_code = request.locale.iso_code | default: 'pt' %}
    <div id="omafit-ar-block-placed" hidden aria-hidden="true"></div>
    {% if settings.type_body_font != blank %}
      <style id="omafit-ar-theme-font-face">{{ settings.type_body_font | font_face: font_display: 'swap' }}</style>
    {% elsif settings.type_heading_font != blank %}
      <style id="omafit-ar-theme-font-face">{{ settings.type_heading_font | font_face: font_display: 'swap' }}</style>
    {% endif %}
    {% comment %}
      MindAR / Euler / pose: valores fixos Omafit (não expostos ao lojista).
      Calibração visual (rotação/altura/tamanho) vem do metafield omafit.ar_calibration
      definido pela página "Calibrar posição" no admin.
    {% endcomment %}
    {% comment %}
      Regra da calibração no runtime:
      1) Rotação base (sem metafield): data-ar-canonical-fix-yxz = "0, -180, -90"
         (cima/baixo 0°, esquerda/direita -180°, inclinação lateral -90°).
      2) Com metafield omafit.ar_calibration, sobrepomos os campos guardados.
      3) data-ar-mindar-wear-position só quando há metafield (ajustes finos).

      Como lemos o metafield:
        - Passamos o JSON inteiro via `| json` no DOM. Isso bypassa a diferença
          entre versões do Shopify Liquid que ora entregam `.value` já parseado
          como hash, ora entregam string. O widget parseia no JS.
        - Para manter os data-attrs existentes (model-scale, bridge-y-factor,
          canonical-fix-yxz, mindar-wear-position) também geramos os campos
          aqui via Liquid, tentando os dois caminhos de acesso (com `.value`
          e direto). Assim o widget tem as duas fontes e usa a que existir.
    {% endcomment %}
    {% liquid
      assign cal_mf = product.metafields.omafit.ar_calibration
      assign cal_hash = cal_mf.value
      if cal_hash == blank
        assign cal_hash = cal_mf
      endif
      assign cal_present = false
      assign cal_rx = 0
      assign cal_ry = 0
      assign cal_rz = 0
      assign cal_bridge_y = 0.15
      assign cal_wear_x = 0
      assign cal_wear_y = 0
      assign cal_wear_z = 0
      assign cal_scale = 1
      if cal_hash
        assign cal_present = true
        if cal_hash.rx != blank
          assign cal_rx = cal_hash.rx
        endif
        if cal_hash.ry != blank
          assign cal_ry = cal_hash.ry
        endif
        if cal_hash.rz != blank
          assign cal_rz = cal_hash.rz
        endif
        if cal_hash.bridgeY != blank
          assign cal_bridge_y = cal_hash.bridgeY
        endif
        if cal_hash.wearX != blank
          assign cal_wear_x = cal_hash.wearX
        endif
        if cal_hash.wearY != blank
          assign cal_wear_y = cal_hash.wearY
        endif
        if cal_hash.wearZ != blank
          assign cal_wear_z = cal_hash.wearZ
        endif
        if cal_hash.scale != blank
          assign cal_scale = cal_hash.scale
        endif
      endif
      assign cal_fix_yxz = cal_rx | append: ', ' | append: cal_ry | append: ', ' | append: cal_rz
      assign cal_wear_position = ''
      if cal_present
        assign cal_wear_position = cal_wear_x | append: ' ' | append: cal_wear_y | append: ' ' | append: cal_wear_z
      endif
    %}
    <div
      id="omafit-ar-root"
      class="omafit-ar-root"
      data-ar-glb-version="{{ product.updated_at | date: '%s' }}"
      data-glb-url="{{ glb_url | escape }}"
      data-product-id="{{ product.id }}"
      data-product-title="{{ product.title | escape }}"
      data-product-image="{{ product_image_url | escape }}"
      data-store-logo="{{ logo_url | escape }}"
      data-shop-name="{{ shop.name | escape }}"
      data-font-family="{{ ar_font_stack | escape }}"
      data-locale="{{ locale_code | escape }}"
      data-ar-glb-yxz=""
      data-ar-model-yxz=""
      data-ar-mirror-selfie=""
      data-ar-scene-x-mirror=""
      data-ar-invert-pose-quat=""
      data-ar-pose-source=""
      data-ar-pose-basis=""
      data-ar-mp-matrix-notranspose=""
      data-ar-pose-corr-yxz=""
      data-ar-flip-ipd-axis=""
      data-ar-pose-lerp="0.92"
      data-ar-use-mp-matrix=""
      data-ar-mindar-anchor="168"
      data-ar-mindar-disable-mirror=""
      data-ar-mindar-model-scale="{{ cal_scale }}"
      data-ar-mindar-wear-yxz=""
      data-ar-mindar-wear-position="{{ cal_wear_position }}"
      data-ar-mindar-no-wear-default=""
      data-ar-mindar-skip-glb-wide-align=""
      data-ar-ipd-swap-ends=""
      data-ar-mindar-skip-default-x-flip=""
      data-ar-mindar-disable-ipd-snap=""
      data-ar-mindar-use-face-scale=""
      data-ar-mindar-filter-min-cf=""
      data-ar-mindar-filter-beta=""
      data-ar-bridge-y-factor="{{ cal_bridge_y }}"
      data-ar-canonical-fix-yxz="{{ cal_fix_yxz }}"
      data-ar-omafit-cal-source="{% if cal_present %}metafield:product{% else %}none{% endif %}"
      data-ar-omafit-calibration="{{ cal_mf | json | escape }}"
    ></div>
    <script type="module" src="{{ 'omafit-ar-widget.js' | asset_url }}&omafit_ar_cb={{ block.id }}&t={{ now | date: '%s' }}"></script>
  {% endif %}
{% endif %}

<script src="{{ 'omafit-widget.js' | asset_url }}" defer></script>


{% schema %}
{
  "name": "Omafit embed",
  "target": "body",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "select",
      "id": "default_gender",
      "label": "Gênero padrão (tabela de medidas)",
      "info": "Use quando o produto é majoritariamente para um gênero. O widget usará essa tabela até o cliente escolher. Evita buscar tabela unissex quando você criou só masculina ou feminina.",
      "options": [
        { "value": "", "label": "Não definir (app decide)" },
        { "value": "male", "label": "Masculino" },
        { "value": "female", "label": "Feminino" },
        { "value": "unisex", "label": "Unissex" }
      ],
      "default": ""
    },
    {
      "type": "paragraph",
      "content": "Com GLB em omafit.ar_glb_url: MindAR (omafit-ar-widget.js), cor, texto do link e logo vêm da configuração do widget no admin Omafit; Euler e tracking são fixos no tema."
    }
  ]
}
{% endschema %}
