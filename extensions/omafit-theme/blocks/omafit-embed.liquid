<div
  id="omafit-widget-root"
  data-ar-mindar-wear-yxz="{{ block.settings.ar_mindar_wear_yxz | default: '0, 90, 180' | strip | escape }}"
  data-ar-mindar-wear-position="{{ block.settings.ar_mindar_wear_position | default: '' | strip | escape }}"
  data-shop-domain="{% if shop.myshopify_domain != blank %}{{ shop.myshopify_domain }}{% else %}{% if shop.domain contains '.myshopify.com' %}{{ shop.domain }}{% else %}{{ shop.domain }}.myshopify.com{% endif %}{% endif %}"
  data-shop-name="{{ shop.name | escape }}"
  {% comment %}
    Handle principal: o mais específico entre as coleções do produto (mais segmentos -/_ , desempate por comprimento).
    Não usar só collection.handle da URL — costuma ser a coleção genérica (ex: cuecas) mesmo existindo cuecas-slips.
  {% endcomment %}
  {% if product and product.collections.size > 0 %}
    {% assign omafit_preferred_handle = '' %}
    {% assign omafit_best_seg = 0 %}
    {% assign omafit_best_len = 0 %}
    {% for c in product.collections %}
      {% assign h = c.handle %}
      {% assign hn = h | replace: '_', '-' %}
      {% assign seg_count = hn | split: '-' | size %}
      {% assign h_len = h | size %}
      {% if seg_count > omafit_best_seg %}
        {% assign omafit_best_seg = seg_count %}
        {% assign omafit_best_len = h_len %}
        {% assign omafit_preferred_handle = h %}
      {% elsif seg_count == omafit_best_seg and h_len > omafit_best_len %}
        {% assign omafit_best_len = h_len %}
        {% assign omafit_preferred_handle = h %}
      {% endif %}
    {% endfor %}
    data-collection-handle="{{ omafit_preferred_handle }}"
    {% assign omafit_coll_handles = product.collections | map: 'handle' | join: ',' %}
    {% if collection %}
      {% assign omafit_url_coll = collection.handle %}
      {% assign omafit_url_in_product_colls = false %}
      {% for c in product.collections %}
        {% if c.handle == omafit_url_coll %}
          {% assign omafit_url_in_product_colls = true %}
          {% break %}
        {% endif %}
      {% endfor %}
      {% unless omafit_url_in_product_colls %}
        {% assign omafit_coll_handles = omafit_coll_handles | append: ',' | append: omafit_url_coll %}
      {% endunless %}
    {% endif %}
    data-collection-handles="{{ omafit_coll_handles }}"
  {% elsif collection %}
    data-collection-handle="{{ collection.handle }}"
    data-collection-handles="{{ collection.handle }}"
  {% endif %}
  {% if product %}
    data-product-id="{{ product.id }}"
    data-product-handle="{{ product.handle }}"
    data-product-title="{{ product.title | escape }}"
    data-product-description="{{ product.description | strip_html | strip_newlines | escape }}"
  {% endif %}
  {% if block.settings.default_gender != blank %}
    data-default-gender="{{ block.settings.default_gender }}"
  {% endif %}
></div>

{% comment %}
  URL do GLB AR (metafield omafit.ar_glb_url) para o iframe Netlify (&arGlbUrl=…) e para MindAR no tema (omafit-ar-widget.js).
{% endcomment %}
{% if product %}
  {% assign omafit_mf_glb = product.metafields.omafit.ar_glb_url %}
  {% assign omafit_ar_glb_url = '' %}
  {% if omafit_mf_glb != blank and omafit_mf_glb.value != blank %}
    {% assign omafit_ar_glb_url = omafit_mf_glb.value | strip %}
  {% endif %}
  <script>
    (function () {
      try {
        var u = {{ omafit_ar_glb_url | json }};
        if (typeof u === 'string' && u.trim()) window.__OMAFIT_AR_GLB_URL__ = u.trim();
      } catch (e) {}
    })();
  </script>

  {% assign tag_filter = block.settings.only_tag | strip %}
  {% assign tag_ok = true %}
  {% if tag_filter != '' %}
    {% assign tag_ok = false %}
    {% for t in product.tags %}
      {% if t == tag_filter %}
        {% assign tag_ok = true %}
        {% break %}
      {% endif %}
    {% endfor %}
  {% endif %}

  {% if omafit_ar_glb_url != blank and tag_ok %}
    {% assign glb_url = omafit_ar_glb_url %}
    {% assign product_image_url = '' %}
    {% if product.featured_image %}
      {% assign product_image_url = product.featured_image | image_url: width: 900 %}
    {% elsif product.images.first %}
      {% assign product_image_url = product.images.first | image_url: width: 900 %}
    {% endif %}
    {% assign logo_url = '' %}
    {% if block.settings.store_logo != blank %}
      {% assign logo_url = block.settings.store_logo | image_url: width: 240 %}
    {% elsif shop.brand.logo != blank %}
      {% assign logo_url = shop.brand.logo | image_url: width: 240 %}
    {% elsif shop.brand.square_logo != blank %}
      {% assign logo_url = shop.brand.square_logo | image_url: width: 240 %}
    {% elsif settings.logo != blank %}
      {% assign logo_url = settings.logo | image_url: width: 240 %}
    {% endif %}
    {% liquid
      assign ar_font_stack = ''
      if settings.type_body_font != blank
        assign ar_font_stack = settings.type_body_font.family | append: ', ' | append: settings.type_body_font.fallback_families
      elsif settings.type_heading_font != blank
        assign ar_font_stack = settings.type_heading_font.family | append: ', ' | append: settings.type_heading_font.fallback_families
      endif
    %}
    {% assign locale_code = request.locale.iso_code | default: 'pt' %}
    <div id="omafit-ar-block-placed" hidden aria-hidden="true"></div>
    {% if settings.type_body_font != blank %}
      <style id="omafit-ar-theme-font-face">{{ settings.type_body_font | font_face: font_display: 'swap' }}</style>
    {% elsif settings.type_heading_font != blank %}
      <style id="omafit-ar-theme-font-face">{{ settings.type_heading_font | font_face: font_display: 'swap' }}</style>
    {% endif %}
    <div
      id="omafit-ar-root"
      class="omafit-ar-root"
      style="--omafit-ar-primary: {{ block.settings.primary_color | default: '#810707' | escape }};"
      data-glb-url="{{ glb_url | escape }}"
      data-product-id="{{ product.id }}"
      data-product-title="{{ product.title | escape }}"
      data-product-image="{{ product_image_url | escape }}"
      data-primary-color="{{ block.settings.primary_color | default: '#810707' | escape }}"
      data-store-logo="{{ logo_url | escape }}"
      data-shop-name="{{ shop.name | escape }}"
      data-font-family="{{ ar_font_stack | escape }}"
      data-locale="{{ locale_code | escape }}"
      data-link-text="{{ block.settings.button_label | default: 'Experimentar óculos (AR)' | escape }}"
      data-ar-glb-yxz="{{ block.settings.ar_model_yxz | default: '' | strip | escape }}"
      data-ar-model-yxz="{{ block.settings.ar_model_yxz | default: '' | strip | escape }}"
      data-ar-mirror-selfie="{{ block.settings.ar_mirror_selfie | default: '' | strip | escape }}"
      data-ar-scene-x-mirror="{{ block.settings.ar_scene_x_mirror | default: '' | strip | escape }}"
      data-ar-invert-pose-quat="{{ block.settings.ar_invert_pose_quat | default: '' | strip | escape }}"
      data-ar-pose-source="{{ block.settings.ar_pose_source | default: '' | strip | escape }}"
      data-ar-pose-basis="{{ block.settings.ar_pose_basis | default: '' | strip | escape }}"
      data-ar-mp-matrix-notranspose="{{ block.settings.ar_mp_matrix_notranspose | default: '' | strip | escape }}"
      data-ar-pose-corr-yxz="{{ block.settings.ar_pose_corr_yxz | default: '' | strip | escape }}"
      data-ar-flip-ipd-axis="{{ block.settings.ar_flip_ipd_axis | default: '' | strip | escape }}"
      data-ar-pose-lerp="{{ block.settings.ar_pose_lerp | default: '0.92' | strip | escape }}"
      data-ar-use-mp-matrix="{{ block.settings.ar_use_mp_matrix | default: '' | strip | escape }}"
      data-ar-mindar-anchor="{{ block.settings.ar_mindar_anchor | default: '168' | strip | escape }}"
      data-ar-mindar-disable-mirror="{{ block.settings.ar_mindar_disable_mirror | default: '' | strip | escape }}"
      data-ar-mindar-model-scale="{{ block.settings.ar_mindar_model_scale | default: '' | strip | escape }}"
      data-ar-mindar-wear-yxz="{{ block.settings.ar_mindar_wear_yxz | default: '' | strip | escape }}"
      data-ar-mindar-no-wear-default="{{ block.settings.ar_mindar_no_wear_default | default: '' | strip | escape }}"
      data-ar-mindar-skip-default-x-flip="{{ block.settings.ar_mindar_skip_default_x_flip | default: '' | strip | escape }}"
      data-ar-mindar-disable-ipd-snap="{{ block.settings.ar_mindar_disable_ipd_snap | default: '' | strip | escape }}"
      data-ar-mindar-use-face-scale="{{ block.settings.ar_mindar_use_face_scale | default: '' | strip | escape }}"
      data-ar-mindar-filter-min-cf="{{ block.settings.ar_mindar_filter_min_cf | default: '' | strip | escape }}"
      data-ar-mindar-filter-beta="{{ block.settings.ar_mindar_filter_beta | default: '' | strip | escape }}"
    ></div>
    <script type="module" src="{{ 'omafit-ar-widget.js' | asset_url }}&omafit_ar_cb={{ block.id }}&t={{ now | date: '%s' }}"></script>
  {% endif %}
{% endif %}

<script src="{{ 'omafit-widget.js' | asset_url }}" defer></script>


{% schema %}
{
  "name": "Omafit embed",
  "target": "body",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "select",
      "id": "default_gender",
      "label": "Gênero padrão (tabela de medidas)",
      "info": "Use quando o produto é majoritariamente para um gênero. O widget usará essa tabela até o cliente escolher. Evita buscar tabela unissex quando você criou só masculina ou feminina.",
      "options": [
        { "value": "", "label": "Não definir (app decide)" },
        { "value": "male", "label": "Masculino" },
        { "value": "female", "label": "Feminino" },
        { "value": "unisex", "label": "Unissex" }
      ],
      "default": ""
    },
    {
      "type": "header",
      "content": "AR óculos (MindAR no tema)"
    },
    {
      "type": "paragraph",
      "content": "Com GLB no metafield e filtro de tag satisfeito, este bloco injeta #omafit-ar-root e omafit-ar-widget.js (Netlify não é alterado). Não coloques o bloco «Omafit AR óculos» no mesmo template — IDs duplicados. Euler wear/posição no #omafit-widget-root têm prioridade no script."
    },
    {
      "type": "text",
      "id": "only_tag",
      "label": "Só MindAR se o produto tiver a tag (vazio = sempre com GLB)",
      "info": "Ex.: eyewear. Vazio = qualquer produto com ar_glb_url recebe o script AR."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto do link AR (como o widget de roupa)",
      "default": "Experimentar óculos (AR)"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Cor primária (modal AR)",
      "default": "#810707"
    },
    {
      "type": "image_picker",
      "id": "store_logo",
      "label": "Logo da loja no modal AR (opcional)",
      "info": "Se vazio, usa o logo do tema quando existir."
    },
    {
      "type": "text",
      "id": "ar_mindar_wear_yxz",
      "label": "Euler wear AR (graus X, Y, Z)",
      "default": "0, 90, 180",
      "info": "Também em #omafit-widget-root (prioridade no script). Vazio no atributo do nó AR = o script lê só o embed."
    },
    {
      "type": "text",
      "id": "ar_mindar_wear_position",
      "label": "Posição do óculos AR (metros X, Y, Z)",
      "info": "Vazio = sem desloco extra. data-ar-mindar-wear-position no #omafit-widget-root."
    },
    {
      "type": "header",
      "content": "MindAR (face tracking)"
    },
    {
      "type": "paragraph",
      "content": "Snap IPD, espelho, Euler glbBind. Mover o GLB: posição no #omafit-widget-root acima."
    },
    {
      "type": "text",
      "id": "ar_mindar_anchor",
      "label": "Índice do landmark âncora",
      "default": "168",
      "info": "168 = ponte do nariz. data-ar-mindar-anchor."
    },
    {
      "type": "text",
      "id": "ar_mindar_disable_mirror",
      "label": "Desligar espelho selfie (vídeo)",
      "info": "1/true/on = vídeo sem espelho. data-ar-mindar-disable-mirror."
    },
    {
      "type": "text",
      "id": "ar_mindar_model_scale",
      "label": "Multiplicador de escala do GLB",
      "info": "Vazio = 1. data-ar-mindar-model-scale."
    },
    {
      "type": "text",
      "id": "ar_mindar_skip_default_x_flip",
      "label": "Sem espelho X por defeito no modelo",
      "info": "Com snap IPD desligado. 1/true/on. data-ar-mindar-skip-default-x-flip."
    },
    {
      "type": "text",
      "id": "ar_mindar_disable_ipd_snap",
      "label": "Desligar snap IPD",
      "info": "1/true/on. data-ar-mindar-disable-ipd-snap."
    },
    {
      "type": "text",
      "id": "ar_mindar_no_wear_default",
      "label": "(Legado) Sem correção wear por defeito",
      "info": "Ignorado pelo script; deixa em branco."
    },
    {
      "type": "text",
      "id": "ar_mindar_use_face_scale",
      "label": "Afinar escala ao rosto (faceScale)",
      "info": "1/true/on. data-ar-mindar-use-face-scale."
    },
    {
      "type": "text",
      "id": "ar_mindar_filter_min_cf",
      "label": "MindAR filterMinCF (opcional)",
      "info": "data-ar-mindar-filter-min-cf."
    },
    {
      "type": "text",
      "id": "ar_mindar_filter_beta",
      "label": "MindAR filterBeta (opcional)",
      "info": "data-ar-mindar-filter-beta."
    },
    {
      "type": "header",
      "content": "Orientação do GLB (Euler)"
    },
    {
      "type": "paragraph",
      "content": "MindAR: espelho selfie, pose, matriz MediaPipe quando aplicável."
    },
    {
      "type": "text",
      "id": "ar_mirror_selfie",
      "label": "Espelho selfie (vídeo MindAR)",
      "info": "data-ar-mirror-selfie."
    },
    {
      "type": "text",
      "id": "ar_scene_x_mirror",
      "label": "Alternar espelho X do modelo",
      "info": "data-ar-scene-x-mirror."
    },
    {
      "type": "text",
      "id": "ar_invert_pose_quat",
      "label": "Inverter orientação do modelo (180° Y)",
      "info": "data-ar-invert-pose-quat."
    },
    {
      "type": "text",
      "id": "ar_pose_source",
      "label": "Fonte da rotação da pose",
      "info": "data-ar-pose-source."
    },
    {
      "type": "text",
      "id": "ar_pose_basis",
      "label": "Forçar só landmarks (makeBasis)",
      "info": "data-ar-pose-basis."
    },
    {
      "type": "text",
      "id": "ar_mp_matrix_notranspose",
      "label": "Matriz MP sem transpor",
      "info": "data-ar-mp-matrix-notranspose."
    },
    {
      "type": "text",
      "id": "ar_pose_corr_yxz",
      "label": "Euler poseCorr (graus X,Y,Z)",
      "info": "data-ar-pose-corr-yxz."
    },
    {
      "type": "text",
      "id": "ar_use_mp_matrix",
      "label": "Usar matriz MediaPipe (rotação)",
      "info": "data-ar-use-mp-matrix."
    },
    {
      "type": "text",
      "id": "ar_pose_lerp",
      "label": "Suavização pose (0.2–1)",
      "default": "0.92",
      "info": "data-ar-pose-lerp."
    },
    {
      "type": "text",
      "id": "ar_flip_ipd_axis",
      "label": "Inverter eixo interpupilar",
      "info": "data-ar-flip-ipd-axis."
    },
    {
      "type": "text",
      "id": "ar_model_yxz",
      "label": "Euler glbBind (graus X,Y,Z)",
      "info": "data-ar-glb-yxz / data-ar-model-yxz."
    }
  ]
}
{% endschema %}
