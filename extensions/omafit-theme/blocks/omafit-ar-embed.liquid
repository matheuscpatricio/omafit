{% comment %}
  Omafit AR óculos — metafield product.metafields.omafit.ar_glb_url (url).
  UI alinhada ao TryOnWidget (etapa info) + link estilo omafit-widget.js; fluxo: info → AR (câmera).
{% endcomment %}
{% assign mf = product.metafields.omafit.ar_glb_url %}
{% assign glb_url = '' %}
{% if mf != blank and mf.value != blank %}
  {% assign glb_url = mf.value | strip %}
{% endif %}
{% assign tag_filter = block.settings.only_tag | strip %}
{% assign tag_ok = true %}
{% if tag_filter != '' %}
  {% assign tag_ok = false %}
  {% for t in product.tags %}
    {% if t == tag_filter %}
      {% assign tag_ok = true %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign product_image_url = '' %}
{% if product.featured_image %}
  {% assign product_image_url = product.featured_image | image_url: width: 900 %}
{% elsif product.images.first %}
  {% assign product_image_url = product.images.first | image_url: width: 900 %}
{% endif %}

{% assign logo_url = '' %}
{% if block.settings.store_logo != blank %}
  {% assign logo_url = block.settings.store_logo | image_url: width: 240 %}
{% elsif settings.logo %}
  {% assign logo_url = settings.logo | image_url: width: 240 %}
{% endif %}

{% assign locale_code = request.locale.iso_code | default: 'pt' %}

{% comment %}
  Marcador para omafit-widget.js: produto elegível para AR (tag) ou opção explícita — esconde provador de roupa
  mesmo sem GLB ainda. data-glb-url em #omafit-ar-root também suprime, mas alguns browsers/atributos falham cedo.
{% endcomment %}
{% if block.settings.hide_clothing_tryon %}
  <div id="omafit-suppress-clothing-widget" hidden aria-hidden="true"></div>
{% elsif tag_filter != '' and tag_ok %}
  <div id="omafit-suppress-clothing-widget" hidden aria-hidden="true"></div>
{% endif %}

{% if glb_url != blank and tag_ok %}
  <div
    id="omafit-ar-root"
    class="omafit-ar-root"
    data-glb-url="{{ glb_url | escape }}"
    data-product-id="{{ product.id }}"
    data-product-title="{{ product.title | escape }}"
    data-product-image="{{ product_image_url | escape }}"
    data-primary-color="{{ block.settings.primary_color | escape }}"
    data-store-logo="{{ logo_url | escape }}"
    data-locale="{{ locale_code | escape }}"
    data-link-text="{{ block.settings.button_label | escape }}"
  ></div>
  <script type="module" src="{{ 'omafit-ar-widget.js' | asset_url }}"></script>
{% endif %}

{% schema %}
{
  "name": "Omafit AR óculos",
  "target": "body",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto do link (como o widget de roupa)",
      "default": "Experimentar óculos (AR)"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Cor primária",
      "default": "#810707"
    },
    {
      "type": "image_picker",
      "id": "store_logo",
      "label": "Logo da loja (opcional)",
      "info": "Se vazio, usa o logo do tema quando existir."
    },
    {
      "type": "text",
      "id": "only_tag",
      "label": "Só exibir se o produto tiver a tag (vazio = sempre que houver GLB)",
      "info": "Ex.: eyewear. Deixa em branco no editor para mostrar sempre que existir GLB."
    },
    {
      "type": "checkbox",
      "id": "hide_clothing_tryon",
      "label": "Ocultar provador de roupa Omafit nesta página",
      "default": false,
      "info": "Ative em templates só de óculos ou quando o bloco AR está no mesmo product template que o embed de roupa. Também suprimimos se preencheres a tag acima e o produto a tiver, ou se já existir GLB AR."
    }
  ]
}
{% endschema %}
