{% comment %}
  Omafit AR óculos — metafield product.metafields.omafit.ar_glb_url (url).
  UI alinhada ao TryOnWidget (etapa info) + link estilo omafit-widget.js; fluxo: info → AR (câmera).
  Tracking facial: MindAR.js (face mesh), como o try-on oficial — hiukim/mind-ar-js.
  Sempre que este bloco está no template, omafit-widget.js não abre o iframe de roupa (omafit.netlify.app/widget).
  Usa um template de produto só para óculos, ou remove este bloco dos templates de roupa.
{% endcomment %}
<div id="omafit-ar-block-placed" hidden aria-hidden="true"></div>
{% assign mf = product.metafields.omafit.ar_glb_url %}
{% assign glb_url = '' %}
{% if mf != blank and mf.value != blank %}
  {% assign glb_url = mf.value | strip %}
{% endif %}
{% assign tag_filter = block.settings.only_tag | strip %}
{% assign tag_ok = true %}
{% if tag_filter != '' %}
  {% assign tag_ok = false %}
  {% for t in product.tags %}
    {% if t == tag_filter %}
      {% assign tag_ok = true %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign product_image_url = '' %}
{% if product.featured_image %}
  {% assign product_image_url = product.featured_image | image_url: width: 900 %}
{% elsif product.images.first %}
  {% assign product_image_url = product.images.first | image_url: width: 900 %}
{% endif %}

{% assign logo_url = '' %}
{% if block.settings.store_logo != blank %}
  {% assign logo_url = block.settings.store_logo | image_url: width: 240 %}
{% elsif shop.brand.logo != blank %}
  {% assign logo_url = shop.brand.logo | image_url: width: 240 %}
{% elsif shop.brand.square_logo != blank %}
  {% assign logo_url = shop.brand.square_logo | image_url: width: 240 %}
{% elsif settings.logo != blank %}
  {% assign logo_url = settings.logo | image_url: width: 240 %}
{% endif %}

{% comment %} Stack de fontes para o widget (body ou heading — muitos temas não preenchem só body). {% endcomment %}
{% liquid
  assign ar_font_stack = ''
  if settings.type_body_font != blank
    assign ar_font_stack = settings.type_body_font.family | append: ', ' | append: settings.type_body_font.fallback_families
  elsif settings.type_heading_font != blank
    assign ar_font_stack = settings.type_heading_font.family | append: ', ' | append: settings.type_heading_font.fallback_families
  endif
%}

{% assign locale_code = request.locale.iso_code | default: 'pt' %}

{% if glb_url != blank and tag_ok %}
  {% if settings.type_body_font != blank %}
    <style id="omafit-ar-theme-font-face">{{ settings.type_body_font | font_face: font_display: 'swap' }}</style>
  {% elsif settings.type_heading_font != blank %}
    <style id="omafit-ar-theme-font-face">{{ settings.type_heading_font | font_face: font_display: 'swap' }}</style>
  {% endif %}
  <div
    id="omafit-ar-root"
    class="omafit-ar-root"
    style="--omafit-ar-primary: {{ block.settings.primary_color | escape }};"
    data-glb-url="{{ glb_url | escape }}"
    data-product-id="{{ product.id }}"
    data-product-title="{{ product.title | escape }}"
    data-product-image="{{ product_image_url | escape }}"
    data-primary-color="{{ block.settings.primary_color | escape }}"
    data-store-logo="{{ logo_url | escape }}"
    data-shop-name="{{ shop.name | escape }}"
    data-font-family="{{ ar_font_stack | escape }}"
    data-locale="{{ locale_code | escape }}"
    data-link-text="{{ block.settings.button_label | escape }}"
    data-ar-glb-yxz="{{ block.settings.ar_model_yxz | default: '' | strip | escape }}"
    data-ar-model-yxz="{{ block.settings.ar_model_yxz | default: '' | strip | escape }}"
    data-ar-mirror-selfie="{{ block.settings.ar_mirror_selfie | default: '' | strip | escape }}"
    data-ar-scene-x-mirror="{{ block.settings.ar_scene_x_mirror | default: '' | strip | escape }}"
    data-ar-invert-pose-quat="{{ block.settings.ar_invert_pose_quat | default: '' | strip | escape }}"
    data-ar-pose-source="{{ block.settings.ar_pose_source | default: '' | strip | escape }}"
    data-ar-pose-basis="{{ block.settings.ar_pose_basis | default: '' | strip | escape }}"
    data-ar-mp-matrix-notranspose="{{ block.settings.ar_mp_matrix_notranspose | default: '' | strip | escape }}"
    data-ar-pose-corr-yxz="{{ block.settings.ar_pose_corr_yxz | default: '' | strip | escape }}"
    data-ar-flip-ipd-axis="{{ block.settings.ar_flip_ipd_axis | default: '' | strip | escape }}"
    data-ar-pose-lerp="{{ block.settings.ar_pose_lerp | default: '0.92' | strip | escape }}"
    data-ar-use-mp-matrix="{{ block.settings.ar_use_mp_matrix | default: '' | strip | escape }}"
    data-ar-mindar-anchor="{{ block.settings.ar_mindar_anchor | default: '168' | strip | escape }}"
    data-ar-mindar-disable-mirror="{{ block.settings.ar_mindar_disable_mirror | default: '' | strip | escape }}"
    data-ar-mindar-model-scale="{{ block.settings.ar_mindar_model_scale | default: '' | strip | escape }}"
    data-ar-mindar-wear-yxz="{{ block.settings.ar_mindar_wear_yxz | default: '' | strip | escape }}"
    data-ar-mindar-use-face-scale="{{ block.settings.ar_mindar_use_face_scale | default: '' | strip | escape }}"
    data-ar-mindar-filter-min-cf="{{ block.settings.ar_mindar_filter_min_cf | default: '' | strip | escape }}"
    data-ar-mindar-filter-beta="{{ block.settings.ar_mindar_filter_beta | default: '' | strip | escape }}"
  ></div>
  {% comment %} block.id + now quebram cache CDN/browser para o JS AR. {% endcomment %}
  <script type="module" src="{{ 'omafit-ar-widget.js' | asset_url }}&omafit_ar_cb={{ block.id }}&t={{ now | date: '%s' }}"></script>
{% endif %}

{% schema %}
{
  "name": "Omafit AR óculos",
  "target": "body",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    {
      "type": "text",
      "id": "button_label",
      "label": "Texto do link (como o widget de roupa)",
      "default": "Experimentar óculos (AR)"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Cor primária",
      "default": "#810707"
    },
    {
      "type": "image_picker",
      "id": "store_logo",
      "label": "Logo da loja (opcional)",
      "info": "Se vazio, usa o logo do tema quando existir."
    },
    {
      "type": "text",
      "id": "only_tag",
      "label": "Só exibir se o produto tiver a tag (vazio = sempre que houver GLB)",
      "info": "Ex.: eyewear. Deixa em branco no editor para mostrar sempre que existir GLB."
    },
    {
      "type": "header",
      "content": "MindAR (face tracking)"
    },
    {
      "type": "paragraph",
      "content": "MindAR.js + Three (hiukim/mind-ar-js). Espelho vídeo: `Desligar espelho MindAR` ou, se vazio, `Espelho selfie`. Euler wear/glbBind/poseCorr, espelho X, flip IPD, invert 180° Y e faceScale afinam o GLB."
    },
    {
      "type": "text",
      "id": "ar_mindar_anchor",
      "label": "Índice do landmark âncora",
      "default": "168",
      "info": "168 = ponte do nariz (como o demo try-on do MindAR). 0–477. data-ar-mindar-anchor."
    },
    {
      "type": "text",
      "id": "ar_mindar_disable_mirror",
      "label": "Desligar espelho selfie (vídeo)",
      "info": "Se preencher, prevalece sobre `Espelho selfie` abaixo. 1/true/on = vídeo sem espelho (MindAR disableFaceMirror). data-ar-mindar-disable-mirror."
    },
    {
      "type": "text",
      "id": "ar_mindar_model_scale",
      "label": "Multiplicador de escala do GLB",
      "info": "Vazio = 1. Ex.: 1.2 para aumentar ligeiramente. data-ar-mindar-model-scale."
    },
    {
      "type": "text",
      "id": "ar_mindar_wear_yxz",
      "label": "Euler wear (graus: X, Y, Z — composição YXZ no Three)",
      "info": "Três números = graus em X, Y e Z (não trocar a ordem dos números). Ex.: 0,180,0 ou -90,0,0. data-ar-mindar-wear-yxz."
    },
    {
      "type": "text",
      "id": "ar_mindar_use_face_scale",
      "label": "Afinar escala ao rosto (faceScale MindAR)",
      "info": "1 / true / on = no 1.º frame com face ajusta escala ao faceScale (largura facial). data-ar-mindar-use-face-scale."
    },
    {
      "type": "text",
      "id": "ar_mindar_filter_min_cf",
      "label": "MindAR filterMinCF (opcional)",
      "info": "Número fino (ex. 0.001). Vazio = defeito da biblioteca. data-ar-mindar-filter-min-cf."
    },
    {
      "type": "text",
      "id": "ar_mindar_filter_beta",
      "label": "MindAR filterBeta (opcional)",
      "info": "Número (ex. 10). Vazio = defeito da biblioteca. data-ar-mindar-filter-beta."
    },
    {
      "type": "header",
      "content": "Orientação do GLB (Euler)"
    },
    {
      "type": "paragraph",
      "content": "Com MindAR: Euler glbBind/poseCorr, espelho X + flip interpupilar, invert pose quat e espelho selfie (se `desligar espelho MindAR` vazio) aplicam-se ao modelo/vídeo. As opções só MediaPipe (pose-source, matrix, lerp…) ignoram-se."
    },
    {
      "type": "text",
      "id": "ar_mirror_selfie",
      "label": "Espelho selfie (vídeo MindAR)",
      "info": "Só usado se `Desligar espelho selfie MindAR` estiver vazio. 1/true/on = vídeo espelhado (defeito); 0/false/off = sem espelho. data-ar-mirror-selfie."
    },
    {
      "type": "text",
      "id": "ar_scene_x_mirror",
      "label": "Inverter eixo X do modelo (espelho local)",
      "info": "Vazio = desligado. 1 = scale.x −1 no GLB sob MindAR (orelha/espelhamento lateral errados). No motor antigo VTG tinha outro efeito. data-ar-scene-x-mirror."
    },
    {
      "type": "text",
      "id": "ar_invert_pose_quat",
      "label": "Inverter orientação do modelo (180° Y)",
      "info": "MindAR: rotação 180° em Y no GLB relativamente à âncora (substituto simples do antigo invert quat VTG). data-ar-invert-pose-quat."
    },
    {
      "type": "text",
      "id": "ar_pose_source",
      "label": "Fonte da rotação da pose",
      "info": "Vazio ou matrix = rotação da matriz MP (recom.) + posição planar. landmarks = só olhos/plano (sem matriz). data-ar-pose-source."
    },
    {
      "type": "text",
      "id": "ar_pose_basis",
      "label": "Forçar só landmarks (makeBasis)",
      "info": "1 = ignorar matriz mesmo com pose-source=matrix. data-ar-pose-basis."
    },
    {
      "type": "text",
      "id": "ar_mp_matrix_notranspose",
      "label": "Matriz MP sem transpor",
      "info": "Vazio = transpor packed (row→column Three). 1 se a rotação com matriz estiver errada. data-ar-mp-matrix-notranspose."
    },
    {
      "type": "text",
      "id": "ar_pose_corr_yxz",
      "label": "Euler poseCorr (graus X,Y,Z)",
      "info": "Entre faceRoot e glbBind. Vazio = 0,0,0. Ex.: 0,180,180 para alguns GLB. data-ar-pose-corr-yxz."
    },
    {
      "type": "text",
      "id": "ar_use_mp_matrix",
      "label": "Usar matriz MediaPipe (rotação)",
      "info": "Vazio = só landmarks (recomendado no modo pixel). 1 = tentar quaternion da matriz facial. data-ar-use-mp-matrix."
    },
    {
      "type": "text",
      "id": "ar_pose_lerp",
      "label": "Suavização pose (0.2–1)",
      "default": "0.92",
      "info": "1 = máximo seguimento ao rosto; mais baixo = mais suave. Ao perder a face e voltar, o GLB faz snap outra vez. data-ar-pose-lerp."
    },
    {
      "type": "text",
      "id": "ar_flip_ipd_axis",
      "label": "Inverter eixo interpupilar (espelho X local)",
      "info": "MindAR: scale.x −1 no GLB (como inverter lateral); combinado com `Inverter eixo X` duas vezes anulam-se. data-ar-flip-ipd-axis."
    },
    {
      "type": "text",
      "id": "ar_model_yxz",
      "label": "Euler glbBind (graus X,Y,Z)",
      "info": "Opcional com MindAR: vazio = identidade. Exporta para data-ar-glb-yxz e data-ar-model-yxz (mesmo valor)."
    }
  ]
}
{% endschema %}
